{
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2020",
    "lib": ["ES2020"],
    "declaration": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "rootDir": "./src",
    "incremental": true,
    "allowJs": true,
    "skipLibCheck": true,
    "strictNullChecks": false,
    "strict": false,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "moduleResolution": "node",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "paths": {
      "@/*": ["./src/*"],
      "@common/*": ["./src/common/*"],
      "@auth/*": ["./src/auth/*"],
      "@startup/*": ["./src/startup/*"],
      "@chat/*": ["./src/chat/*"],
      "@ai/*": ["./src/ai/*"],
      "@roadmap/*": ["./src/roadmap/*"],
      "@database/*": ["./src/database/*"],
      "@redis-store/*": ["./src/redis-store/*"],
      "@config/*": ["./src/config/*"]
    }
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist", "test", "**/*spec.ts"]
}
